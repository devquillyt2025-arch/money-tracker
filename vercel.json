{
  "version": 2,
  "buildCommand": "vite build && npx esbuild _api/index.ts --bundle --platform=node --format=esm --external:pg-native --outfile=api/index.mjs",
  "outputDirectory": "dist",
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
